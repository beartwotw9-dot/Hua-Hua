# DoraOS core
DORAOS_ROOT=/absolute/path/to/DoraOS
OBSIDIAN_VAULT_PATH=/absolute/path/to/DoraOS/obsidian/DoraOS
DORAOS_ENV=local

# Knowledge + memory
MEMORY_DB_PATH=/absolute/path/to/DoraOS/memory/dora_memory.sqlite
VECTOR_DB_DIR=/absolute/path/to/DoraOS/memory/chroma
MEMORY_INDEXER_ENABLED=true
MEMORY_SYNC_INTERVAL_MINUTES=30
MEMORY_MAX_NOTE_CHARS=12000

# OpenHuman
OPENHUMAN_ENABLED=true
OPENHUMAN_WORKSPACE=/Users/your-user/.openhuman
OPENHUMAN_NOTIFICATIONS_DB=
OPENHUMAN_OBSIDIAN_EXPORT_DIR=/absolute/path/to/DoraOS/obsidian/DoraOS/Resources/OpenHuman
OPENHUMAN_MODEL=
OPENHUMAN_LOCAL_AI_TIER=medium
OPENHUMAN_ANALYTICS_ENABLED=false

# LINE notification router
# Uses LINE Messaging API push messages. Keep disabled until token/user id are set.
LINE_ROUTER_ENABLED=false
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_TO_USER_ID=
LINE_ROUTER_SOURCES=discord
LINE_ROUTER_DISCORD_STATUSES=unread,read,acted
LINE_ROUTER_MAX_ITEMS_PER_RUN=200
LINE_ROUTER_STATE_PATH=
LINE_DAILY_BRIEF_ENABLED=true
LINE_DAILY_BRIEF_STATE_PATH=
LINE_TASKS_BRIEF_ENABLED=true
LINE_TASKS_BRIEF_STATE_PATH=
LINE_AI_MODEL=openai/gpt-4.1-mini
LINE_AI_ALLOW_EXTERNAL_CONTEXT=false
LINE_AI_NOTION_WRITES_ENABLED=false
LINE_AI_NOTION_NOTES_DB_ID=
LINE_AI_NOTION_PARENT_PAGE_ID=
DORAOS_MARKET_WATCHLIST=0050.TW:0050 元大台灣50,QQQ:QQQ Nasdaq 100 ETF,VT:VT Vanguard 全球股票
# Optional private holdings format, keep real holdings in DoraOS/.env only:
# DORAOS_MARKET_HOLDINGS=symbol|label|shares|avg_cost|currency;symbol|label|shares|avg_cost|currency
DORAOS_NEWS_QUERIES=台股 AI 半導體;美股 AI 科技;台灣 金融市場

# Local AI
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_FAST_MODEL=gemma3:4b
OLLAMA_EMBED_MODEL=embeddinggemma

# Cloud routing
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PRIMARY_REASONING_MODEL=openai/gpt-4.1
FALLBACK_REASONING_MODEL=anthropic/claude-3.7-sonnet
LOW_COST_MODEL=google/gemini-2.5-flash

# GitHub
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Google / Gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
GMAIL_SYNC_ENABLED=false
GOOGLE_OAUTH_CREDENTIALS_PATH=
GOOGLE_TOKEN_PATH=
GMAIL_DIGEST_QUERY=in:inbox is:unread newer_than:3d
GOOGLE_CALENDAR_TIMEZONE=Asia/Taipei

# Official weather / market sources
# CWA key is required for official weather. TWSE market endpoint does not need a key.
CWA_API_KEY=
CWA_LOCATION_NAME=臺北市

# Retry settings for all sync scripts (Gmail, Calendar, Research, Notion)
# Increase SYNC_RETRY_ATTEMPTS if you see frequent DNS/network failures in logs
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_BACKOFF_SECONDS=2.0

# How long (seconds) to wait for network to become available at script startup
# Increase if your machine takes >60s to get DNS after wake/boot
NETWORK_WARMUP_TIMEOUT=60

# Optional: Semantic Scholar API key for higher rate limits (100 req/s vs 1 req/s)
# Get one free at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
ZOTERO_LIBRARY_PATH=~/Zotero/zotero.sqlite
ZOTERO_BRIDGE_CONFIG_PATH=/absolute/path/to/DoraOS/config/zotero_bridge.config.example.json

# Notion
NOTION_API_KEY=
NOTION_HEALING_DB_ID=

# Linear
# Personal API key used only for read-only daily brief fetching.
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_SYNC_ENABLED=false

# Observability
LOG_LEVEL=info
ENABLE_PROMPT_LOGGING=false
ENABLE_TOOL_AUDIT_LOG=true
